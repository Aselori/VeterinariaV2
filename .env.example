# Copia este archivo a .env.local y completa los valores.

# Base de datos SQLite (ruta relativa a la raíz del proyecto)
DATABASE_URL="file:./prisma/dev.db"

# Secreto de NextAuth v5 — genera uno con:
#   openssl rand -base64 32
AUTH_SECRET=

# API key de Google Gemini para el chatbot VetBot
# Obtén una gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
